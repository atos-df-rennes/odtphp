{
    "name": "cybermonde/odtphp",
    "description": "ODT document generator",
    "keywords": [
        "odt",
        "php"
    ],
	"license": "GPL-3.0",
    "type": "library",
    "homepage": "https://github.com/atos-df-rennes/odtphp",
    "require": {
        "php": "^7.4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "phpstan/phpstan": "^2.0",
        "phpstan/extension-installer": "^1.3",
        "rector/rector": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.22",
        "symfony/var-dumper": "^5.4"
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse --memory-limit=-1",
        "generate-baseline": "vendor/bin/phpstan --memory-limit=-1 --generate-baseline",
        "refactor": "vendor/bin/rector",
        "cs-fix": "vendor/bin/php-cs-fixer fix",
        "test": "vendor/bin/phpunit --testdox",
        "test-coverage": "@test --coverage-html tests/coverage/ --whitelist src/"
    },
    "autoload": {
        "psr-4": {
            "Odtphp\\": "src"
        },
        "files": ["lib/pclzip.lib.php"]
    },
    "autoload-dev": {
        "psr-4": {
            "Odtphp\\Test\\": "tests"
        },
        "files": ["lib/pclzip.lib.php"]
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "2.0-dev"
        }
    }
}
